# ── App ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Database ─────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mydb

QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Models ───────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=gpt-4o
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Search ───────────────────────────────────
TOP_K=10
SCORE_THRESHOLD=0.5
